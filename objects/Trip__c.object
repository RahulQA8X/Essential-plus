        <description>Including Proccessing Fees</description>
        <label>Trip Amount(Including Proccessing Fees)</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
